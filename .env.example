# Server-only API-Sports credential used by the widget proxy and result sync.
# Never prefix this with NEXT_PUBLIC_ and never place it in widget data-key.
API_FOOTBALL_KEY=

# Turso/libSQL persistence. Vercel Marketplace injects both values in production.
# Local development can leave these blank and uses file:.data/qiuju.db instead.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
